    "dotenv": "^16.3.1",
    "fs-extra": "^11.2.0",
    "proxy-agent": "^6.4.0",
    "puppeteer": "^24.22.3",
    "rate-limiter-flexible": "^5.0.3",
    "user-agents": "^1.1.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.3"
