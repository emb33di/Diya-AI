{
  "name": "essay-prompt-scraper",
  "version": "1.0.0",
  "description": "Web scraper for collecting essay prompts from various university websites",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "scrape": "node src/scraper.js",
    "scrape-cea": "node run-cea-scraper.js",
    "scrape-full": "node run-full-scraper.js",
