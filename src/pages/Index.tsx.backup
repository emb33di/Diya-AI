import { useEffect, useState } from "react";
import { useNavigate } from "react-router-dom";
import { supabase } from "@/integrations/supabase/client";
import { Button } from "@/components/ui/button";
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card";
import { Link } from "react-router-dom";
import { CheckCircle, Users, PenTool, Calendar, Target, MessageSquare, BookOpen } from "lucide-react";

const Index = () => {
  const navigate = useNavigate();
  const [isLoading, setIsLoading] = useState(true);

  useEffect(() => {
    const checkAuth = async () => {
      try {
        const { data: { user } } = await supabase.auth.getUser();
        if (user) {
          // User is logged in, redirect to dashboard
          navigate('/dashboard', { replace: true });
        } else {
          // User is not logged in, show landing page
          setIsLoading(false);
        }
      } catch (error) {
        console.error('Error checking authentication:', error);
        setIsLoading(false);
      }
    };

    checkAuth();
  }, [navigate]);

  // Show loading while checking authentication
  if (isLoading) {
    return (
      <div className="min-h-screen bg-background flex items-center justify-center">
        <div className="text-center">
          <div className="animate-spin rounded-full h-12 w-12 border-b-2 border-primary mx-auto mb-4"></div>
          <p className="text-muted-foreground">Loading...</p>
        </div>
      </div>
    );
  }

  // Landing page content for non-authenticated users
  const features = [
    {
      icon: MessageSquare,
      title: "Voice-Powered Intake",
      description: "Start with a conversational assessment that understands your goals, background, and dream schools."
    },
    {
      icon: Target,
      title: "Personalized Roadmap",
      description: "Get a custom admissions strategy with Dream, Target, and Safety school recommendations."
    },
    {
      icon: PenTool,
      title: "AI Essay Assistant",
      description: "Brainstorm, draft, and refine your personal statements with intelligent feedback."
    },
    {
      icon: Calendar,
      title: "Deadline Tracking",
      description: "Never miss a deadline with smart reminders and progress tracking."
    }
  ];

  const testimonials = [
    {
      name: "Emily Chen",
      school: "Admitted to Stanford",
      quote: "The essay feedback helped me find my authentic voice and tell my story in a compelling way."
    },
    {
      name: "Marcus Johnson",
      school: "Admitted to Harvard",
      quote: "The personalized roadmap kept me organized and confident throughout the entire process."
    }
  ];

  return (
    <div className="min-h-screen bg-background">
      <div className="bg-gradient-to-br from-background via-primary/5 to-secondary/10 p-4 min-h-screen">
      
      
      {/* Hero Section */}
      <section className="relative overflow-hidden py-20 md:py-32">
        <div className="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-secondary/5"></div>
        <div className="container mx-auto px-6 text-center relative">
          <div className="animate-fade-in">
            <div className="mb-6">
              <div className="inline-flex items-center px-4 py-2 rounded-full bg-primary/10 border border-primary/20 mb-4">
                <span className="text-sm font-medium text-primary">Founded & Backed by Ivy League Alumni</span>
              </div>
            </div>
            <h1 className="text-5xl md:text-7xl font-display font-bold mb-8 bg-gradient-hero bg-clip-text text-transparent leading-tight">
              Diya
            </h1>
            <div className="text-2xl md:text-3xl font-semibold mb-6 text-foreground">
              Your 24/7 AI Counselor
            </div>
            <p className="text-xl md:text-2xl text-muted-foreground mb-10 max-w-4xl mx-auto leading-relaxed">
              Designed by <span className="text-primary font-medium">Indian alumni from Harvard and Dartmouth</span> specifically for Indian applicants!
            </p>
            <div className="flex flex-col sm:flex-row gap-6 justify-center items-center mb-16">
              <Link to="/auth">
                <Button size="xl" className="bg-gradient-primary hover:shadow-xl transform hover:scale-105 transition-all duration-200 px-8 py-4 text-lg">
                  Start Your Journey Free
                </Button>
              </Link>
              <Link to="/about">
                <Button size="xl" variant="outline" className="border-2 hover:bg-primary/5 px-8 py-4 text-lg">
                  Meet Our Team
                </Button>
              </Link>
            </div>
          </div>
        </div>
      </section>

      {/* Features Section */}
      <section className="py-20 bg-muted/30">
        <div className="container mx-auto px-6">
          <div className="text-center mb-16">
            <h2 className="text-3xl md:text-4xl font-display font-bold mb-4">
              Everything You Need to Succeed
            </h2>
            <p className="text-lg text-muted-foreground max-w-2xl mx-auto">
              Our comprehensive platform guides you through every step of the admissions process
            </p>
          </div>
          
          <div className="grid grid-cols-1 md:grid-cols-2 gap-8">
            {features.map((feature, index) => (
              <Card key={index} className="shadow-lg hover:shadow-xl transition-shadow bg-background">
                <CardHeader>
                  <div className="flex items-center space-x-3">
                    <div className="h-12 w-12 rounded-lg bg-primary/10 flex items-center justify-center">
                      <feature.icon className="h-6 w-6 text-primary" />
                    </div>
                    <CardTitle className="text-xl">{feature.title}</CardTitle>
                  </div>
                </CardHeader>
                <CardContent>
                  <p className="text-muted-foreground leading-relaxed">{feature.description}</p>
                </CardContent>
              </Card>
            ))}
          </div>
        </div>
      </section>

      {/* Testimonials Section */}
      <section className="py-20">
        <div className="container mx-auto px-6">
          <div className="text-center mb-16">
            <h2 className="text-3xl md:text-4xl font-display font-bold mb-4">
              Success Stories
            </h2>
            <p className="text-lg text-muted-foreground">
              Hear from students who achieved their college dreams
            </p>
          </div>
          
          <div className="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
            {testimonials.map((testimonial, index) => (
              <Card key={index} className="shadow-lg bg-gradient-card">
                <CardContent className="p-8">
                  <p className="text-lg mb-6 italic">"{testimonial.quote}"</p>
                  <div className="flex items-center space-x-3">
                    <div className="h-12 w-12 rounded-full bg-primary/10 flex items-center justify-center">
                      <Users className="h-6 w-6 text-primary" />
                    </div>
                    <div>
                      <p className="font-semibold">{testimonial.name}</p>
                      <p className="text-sm text-muted-foreground">{testimonial.school}</p>
                    </div>
                  </div>
                </CardContent>
              </Card>
            ))}
          </div>
        </div>
      </section>

      {/* CTA Section */}
      <section className="py-20 bg-gradient-hero">
        <div className="container mx-auto px-6 text-center">
          <h2 className="text-3xl md:text-4xl font-display font-bold mb-4 text-primary-foreground">
            Ready to Transform Your Future?
          </h2>
          <p className="text-xl text-primary-foreground/80 mb-8 max-w-2xl mx-auto">
            Join hundreds of students with 24/7 access to expert guidance from Ivy League alumni.
          </p>
          <Link to="/auth">
            <Button size="xl" variant="secondary" className="shadow-xl">
              Get Started Today
            </Button>
          </Link>
        </div>
      </section>
      </div>
    </div>
  );
};

export default Index;
